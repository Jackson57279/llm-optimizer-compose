# Copy this to .env (scripts/setup.ps1 does this automatically on first run) and edit.

# ----- Hugging Face -----
# Required to download gated models (some Unsloth / Meta repos). Get one at
# https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=

# ----- API keys -----
# Any non-empty string works for local use; LiteLLM will require it on inbound calls.
LITELLM_MASTER_KEY=sk-local-dev-key
OPENWEBUI_SECRET_KEY=change-me-please-32-chars-minimum

# ----- Model directories -----
# Where control / smaller models live. Defaults to the pre-existing miniforge
# gguf folder that already holds your MiniMax-M2.7 UD-IQ2_XXS shards.
MODEL_DIR=C:\Users\midwe\miniforge\gguf

# Where the MiniMax-M2.7-161B-REAP-Q2_K (~56 GB) lands. Use the fastest NVMe.
MODEL_DIR_REAP=D:\ai\models

# ----- Engine manager -----
MANAGER_HOST=127.0.0.1
MANAGER_PORT=9292
ENGINES_CONFIG=config/engines.yaml

# ----- miniforge-server defaults -----
MINIFORGE_CONFIG=configs/m7-optimized.yaml
MINIFORGE_LOG_LEVEL=info

# ----- AirLLM -----
AIRLLM_COMPRESSION=4bit
AIRLLM_MAX_CTX=1024

# ----- Misc -----
# llama.cpp Vulkan: restrict which Vulkan device is used (0 = iGPU, 1 = dGPU if any).
GGML_VK_VISIBLE_DEVICES=0
