      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(miniforge_ttft_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "p50 {{job}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(miniforge_ttft_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "p95 {{job}}",
          "refId": "B"
        }
      ],
      "title": "TTFT p50 / p95 by engine",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
