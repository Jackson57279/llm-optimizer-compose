      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(miniforge_tokens_total[5m])) by (direction, job)",
          "legendFormat": "{{direction}} {{job}}",
          "refId": "A"
        }
      ],
      "title": "Tokens/sec by direction",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * sum(rate(miniforge_requests_total{status!~\"2..\"}[5m])) by (endpoint) / sum(rate(miniforge_requests_total[5m])) by (endpoint)",
