# Open WebUI configuration (consumed by scripts/start.ps1 which runs `open-webui serve`).
# Docs: https://docs.openwebui.com/getting-started/env-configuration

# ----- Auth / users -----
# Set to False for single-user local use; flip to True and create an admin if exposing it.
WEBUI_AUTH=False
ENABLE_SIGNUP=False

# Strong random string (>= 32 chars) if WEBUI_AUTH=True. Pulled from .env if present.
WEBUI_SECRET_KEY=change-me-please-32-chars-minimum

# ----- OpenAI backend (LiteLLM proxy) -----
# Every route defined in config/engines.yaml is visible here.
OPENAI_API_BASE_URL=http://127.0.0.1:4000/v1
OPENAI_API_KEY=sk-local-dev-key

# Must match LiteLLM general_settings.master_key / LITELLM_MASTER_KEY (scripts/start.ps1 syncs this when LiteLLM runs).
# Open WebUI stores settings in SQLite by default; stale DB rows ignore env and show "no models".
ENABLE_PERSISTENT_CONFIG=False
ENABLE_OPENAI_API=True

# Disable Ollama discovery — miniforge doesn't use it.
ENABLE_OLLAMA_API=False

# ----- RAG / embeddings -----
# Use a small local embedding model so WebUI doesn't phone home.
RAG_EMBEDDING_ENGINE=
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ENABLE_RAG_LOCAL_WEB_FETCH=True

# ----- Storage -----
# Keep everything inside the workspace so the project is self-contained.
DATA_DIR=./data/openwebui

# ----- Networking / port -----
PORT=8080
HOST=127.0.0.1

# Windows: Python defaults to cp1252; Open WebUI's startup banner uses Unicode and crashes without UTF-8.
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ----- Misc -----
DEFAULT_MODELS=minimax-m27-full-vulkan,qwen3-30b-vulkan
DEFAULT_USER_ROLE=admin
SAFE_MODE=False
WEBUI_NAME=miniforge
